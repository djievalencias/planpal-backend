# ─── Secret backend (compile-time selection) ─────────────────────────────────
# Set SECRET_SOURCE *before* running cargo build to pick a backend with zero
# runtime overhead (static dispatch — no Box<dyn>).
#
#   SECRET_SOURCE=env                 cargo build   ← default, no external deps
#   SECRET_SOURCE=aws_secret_manager  cargo build
#   SECRET_SOURCE=vault               cargo build
#
# The build script (build.rs) translates this into a rustc cfg flag.
SECRET_SOURCE=aws_secret_manager

# Path / name of the secret to fetch.  Ignored by the "env" backend.
SECRET_PATH=planpal/jihad/configuration

# ── AWS Secrets Manager ───────────────────────────────────────────────────────
AWS_REGION=ap-southeast-3
# Credentials come from the IAM / ECS task role or:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ── HashiCorp Vault (KV v2) ───────────────────────────────────────────────────
# VAULT_ADDR=http://vault:8200
# Token auth:  VAULT_TOKEN=s.xxxxxxxxxxxx
# AppRole:     VAULT_ROLE_ID=<role-id>   VAULT_SECRET_ID=<secret-id>

# ── Env backend secret values (SECRET_SOURCE=env / local dev & tests) ─────────
# Prefix every secret key with SECRET_ in upper-snake-case.
SECRET_DATABASE_URL=postgres://planpal:secret@localhost:5432/planpal
SECRET_JWT_SECRET=change-me-to-a-long-random-secret
SECRET_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
SECRET_GOOGLE_CLIENT_SECRET=your-google-client-secret
SECRET_SMTP_USERNAME=noreply@yourcompany.com
SECRET_SMTP_PASSWORD=your-smtp-password
SECRET_FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"...","client_email":"firebase@your-project.iam.gserviceaccount.com","token_uri":"https://oauth2.googleapis.com/token"}
SECRET_SLACK_SIGNING_SECRET=your-slack-signing-secret
SECRET_SLACK_BOT_TOKEN=xoxb-your-bot-token
SECRET_REDIS_URL=redis://127.0.0.1:6379

# ─── Server ───────────────────────────────────────────────────────────────────
APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=8088

# ─── Database (non-sensitive pool settings only) ──────────────────────────────
# database_url is loaded from the secret manager, not from env.
APP__DATABASE__MAX_CONNECTIONS=10
APP__DATABASE__MIN_CONNECTIONS=2

# ─── JWT (non-sensitive expiry settings only) ─────────────────────────────────
# jwt_secret is loaded from the secret manager, not from env.
APP__JWT__EXPIRY_SECONDS=3600
APP__JWT__REFRESH_EXPIRY_SECONDS=604800

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
# google_client_id and google_client_secret are loaded from the secret manager.
APP__GOOGLE__REDIRECT_URI=http://localhost:8088/api/v1/auth/google/callback

# ─── NATS ─────────────────────────────────────────────────────────────────────
APP__NATS__URL=nats://localhost:4222
APP__NATS__SUBJECT_PREFIX=planpal

# ─── Email provider ──────────────────────────────────────────────────────────
# Which transport to use for outbound email: "ses" (AWS SES v2) or "smtp".
# When "ses" is selected, AWS credentials are resolved via the default chain
# (env vars, ECS task role, EC2 instance profile). The region comes from
# AWS_REGION / AWS_DEFAULT_REGION (see above).
# When "smtp" is selected, the SMTP settings below are used.
APP__EMAIL__PROVIDER=smtp

# ─── SMTP (non-sensitive settings only) ──────────────────────────────────────
# smtp_username and smtp_password are loaded from the secret manager.
APP__SMTP__HOST=smtp.gmail.com
APP__SMTP__PORT=587
APP__SMTP__FROM="PlanPal <noreply@yourcompany.com>"

# ─── Application ──────────────────────────────────────────────────────────────
APP__APP__BASE_URL=http://localhost:8088
APP__APP__FRONTEND_URL=http://localhost:3000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Seed admin (used only by `cargo run --bin seed_admin`) ───────────────────
# Never commit real values. Set these in your shell or a secrets manager.
# SEED_ADMIN_EMAIL and SEED_ADMIN_PASSWORD are removed from the environment
# immediately after being read by the binary.
#
# Password requirements: ≥12 chars, uppercase, lowercase, digit, special char.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Change_Me_Now!99
SEED_ADMIN_NAME="System Admin"

# ─── Secret payload (stored in your secret manager, NOT in .env) ─────────────
# The secret at SECRET_PATH must be a JSON object with these keys:
#
# {
#   "database_url":          "postgres://user:pass@host:5432/planpal",
#   "jwt_secret":            "<long-random-string>",
#   "google_client_id":      "<id>.apps.googleusercontent.com",
#   "google_client_secret":  "<secret>",
#   "smtp_username":         "noreply@yourcompany.com",
#   "smtp_password":         "<password>",
#   "fcm_service_account_json": "{\"type\":\"service_account\",\"project_id\":\"...\",\"private_key\":\"...\",\"client_email\":\"...\"}",
#   "slack_signing_secret":  "<slack-signing-secret>",
#   "slack_bot_token":       "xoxb-...",
#   "redis_url":             "redis://:password@host:6379",
#   "email_provider":        "ses",
#   "bedrock_model_id":     "anthropic.claude-3-5-haiku-20241022-v1:0",
#   "bedrock_region":       "us-east-1"
# }
